	Publicationstatus = {Published},
	Tags = {(DDB) Distribution Dynamics Bolivia},
	Title = {Spatial Distribution Dynamics},
	Type = {ERSA conference papers},
	Url = {https://ideas.repec.org/p/wiw/wiwrsa/ersa15p1172.html},
